$TTL 86400
@   IN  SOA ns1.{{ domain_name }}. root.{{ domain_name }}. (
        {{ serial }} ; Serial
        3600       ; Refresh
        1800       ; Retry
        604800     ; Expire
        86400 )    ; Minimum TTL

@    IN  NS     ns1.{{ domain_name }}.
ns1  IN  A      {{ dns_ip }}

{% for record in records %}
{{ record.name }} IN A {{ record.ip }}
{% endfor %}
